##########
# i3 Bar #
##########

bar {
    status_command i3status 
    position bottom
    font pango:Fixed 10
    colors {
        background #C0C0C0
        statusline #000000
        separator  #666666

        focused_workspace  #000080 #343491 #FFFFFF
        active_workspace   #000080 #8C8CAF #000000
        inactive_workspace #333333 #A0A0A0 #000000
        urgent_workspace   #2F343A #FF0000 #FFFFFF
        binding_mode       #2F343A #FF0000 #FFFFFF
    }
}

